generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  role         Role           @default(STUDENT)
  firstName    String
  lastName     String
  profileImage String?
  createdAt    DateTime       @default(now())

  // Relaciones
  tutorProfile TutorProfile?
  studentAppointments Appointment[] @relation("StudentAppointments")
  sentMessages      Message[]     @relation("SentMessages")
  receivedMessages  Message[]     @relation("ReceivedMessages")
  reviewsGiven      Review[]      @relation("ReviewsGiven")
}

enum Role {
  STUDENT
  TUTOR
}

model TutorProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bio          String?
  hourlyRate   Float    @default(0.0)
  balance      Float    @default(0.0)
  latitude     Float?
  longitude    Float?
  subjects     String?

  // Relaciones
  appointments Appointment[] @relation("TutorAppointments")
  reviews      Review[]      @relation("ReviewsReceived")
}

model Appointment {
  id              String   @id @default(uuid())
  studentId       String
  student         User     @relation("StudentAppointments", fields: [studentId], references: [id])
  
  tutorId         String
  tutorProfile    TutorProfile @relation("TutorAppointments", fields: [tutorId], references: [id])
  
  date            DateTime
  durationMinutes Int      @default(60)
  totalPrice      Float    @default(0.0)
  status          Status   @default(PENDING)
  locationNotes   String?

  // Relaciones
  review          Review?
}

enum Status {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Review {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  
  studentId     String
  student       User     @relation("ReviewsGiven", fields: [studentId], references: [id])
  
  tutorId       String
  tutorProfile  TutorProfile @relation("ReviewsReceived", fields: [tutorId], references: [id])
  
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  
  content    String
  createdAt  DateTime @default(now())
  isRead     Boolean  @default(false)
}
